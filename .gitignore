*.suo
*.user
*.userosscache
*.sln.docstates
*.sln.dotsettings.user

# Visual C++ cache files
ipch/
*.aps
*.ncb
*.opendb
*.opensdf
*.sdf
*.cachefile
*.VC.db

# Executable and debug files
*.exe
*.pdb
*.ilk
*.obj
*.pch

# Logs and temporary files
*.log
*.tlog
TestResult.xml
[Bb]uild[Ll]og.*

# 其他常见忽略（根据你的项目可以继续添加）
*.vs/
.vscode/
*.tmp
*.temp
